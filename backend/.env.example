# ===================================
# 10x Team Chat - Environment Config
# chat.10xdigitalventures.com
# ===================================

# Server
PORT=5000
NODE_ENV=production

# Database (Hostinger MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=10xchat
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800

# CORS - Frontend URLs
CLIENT_URL=https://chat.10xdigitalventures.com
CLIENT_URL_DEV=http://localhost:3000
ALLOWED_ORIGINS=https://chat.10xdigitalventures.com,exp://127.0.0.1:8081

# App
APP_NAME=10x Team Chat
APP_URL=https://api.10xdigitalventures.com
PUBLIC_API_URL=https://api.10xdigitalventures.com
